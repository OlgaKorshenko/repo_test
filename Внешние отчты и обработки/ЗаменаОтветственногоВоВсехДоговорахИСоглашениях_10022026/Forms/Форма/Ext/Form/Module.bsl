&НаСервере
Процедура ЗаменитьНеВФонеНаСервере()
	// см. ДополнительныеОтчетыИОбработки.ВыполнитьКоманду.ПараметрыКоманды
	ПараметрыОбработкиЗагрузки = Новый Структура;
	ПараметрыОбработкиЗагрузки.Вставить("ДополнительнаяОбработкаСсылка", Параметры.ДополнительнаяОбработкаСсылка);
	ПараметрыОбработкиЗагрузки.Вставить("ИдентификаторКоманды", "");
	ПараметрыОбработкиЗагрузки.Вставить("Таблица", Объект.Таб.Выгрузить());
	ПараметрыОбработкиЗагрузки.Вставить("КоличествоОбщее", Объект.КоличествоКонтрагентов);
	ПараметрыОбработкиЗагрузки.Вставить("ВсеЗаписиСписком", Объект.ВсеЗаписиСписком.Выгрузить());
	ПараметрыОбработкиЗагрузки.Вставить("Агент", Объект.Агент);
	ПараметрыОбработкиЗагрузки.Вставить("ПоАгенту", Объект.ПоАгенту);
	
	ОбъектОбработка = РеквизитФормыВЗначение("Объект");
	ОбъектОбработка.ВыполнитьКоманду(Неопределено, ПараметрыОбработкиЗагрузки);
КонецПроцедуры


&НаКлиенте
Процедура ЗаменитьНеВФоне(Команда)
	ЗаменитьНеВФонеНаСервере();
КонецПроцедуры

